  "item": [
    {
      "name": "Positive Scenarios",
      "item": [
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseBody = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Access token is not empty\", () => {",
                  "    pm.expect(responseBody.access_token).to.not.be.empty;",
                  "    pm.expect(responseBody.access_token).to.be.a('string');",
                  "});",
                  "",
                  "if (responseBody.access_token !== null) {",
                  "    pm.environment.set(\"access_token_f2\", responseBody.access_token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "password",
                  "value": "{{client_secret}}",
                  "type": "string"
                },
                {
                  "key": "username",
                  "value": "{{client_id}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "refresh_token",
                  "type": "text",
                  "uuid": "edbe2982-7050-405c-9233-f1771a75439d"
                },
                {
                  "key": "refresh_token",
                  "value": "{{refresh_token}}",
                  "type": "text",
                  "uuid": "2f17004f-89a3-4e81-b394-e52df939fea6"
                }
              ]
            },
            "url": {
              "raw": "https://accounts.spotify.com/api/token",
              "protocol": "https",
              "host": ["accounts", "spotify", "com"],
              "path": ["api", "token"]
            }
          },
          "response": []
        },
        {
          "name": "Get /me/playlists",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token_f2}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.spotify.com/v1/me/playlists/",
              "protocol": "https",
              "host": ["api", "spotify", "com"],
              "path": ["v1", "me", "playlists", ""]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Negative Scenarios",
      "item": [
        {
          "name": "Get /me/playlists - No token provided",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "",
                  "pm.test(\"Error message is 'No token provided'\", () => {",
                  "    pm.expect(response.error.message).to.eql('No token provided');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.spotify.com/v1/me/playlists/",
              "protocol": "https",
              "host": ["api", "spotify", "com"],
              "path": ["v1", "me", "playlists", ""]
            }
          },
          "response": []
        }
      ]
    }
  ],
