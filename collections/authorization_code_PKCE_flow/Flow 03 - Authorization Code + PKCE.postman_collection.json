            },
            "url": {
              "raw": "https://accounts.spotify.com/api/token",
              "protocol": "https",
              "host": ["accounts", "spotify", "com"],
              "path": ["api", "token"]
            }
          },
          "response": []
        },
        {
          "name": "04 Get user information",
          "request": {
