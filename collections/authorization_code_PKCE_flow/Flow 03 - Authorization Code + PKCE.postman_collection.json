{
  "info": {
    "name": "Flow 03 - Authorization Code + PKCE",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52148220"
  },
  "item": [
    {
      "name": "Positive Scenarios",
      "item": [
        {
          "name": "01 - Build Authorization URL (Open URL in Browser) Copy",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "",
                  "function generateCodeVerifier(length = 64) {",
                  "    // Generates a random code_verifier (43–128 chars) Code verifier is a random string that is URL-safe and has a length between 43 and 128 characters. It is used to generate a code challenge ",
                  "    const charset = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~\";",
                  "    let verifier = \"\";",
                  "    for (let i = 0; i < length; i++) {",
                  "        verifier += charset.charAt(Math.floor(Math.random() * charset.length));",
                  "    }",
                  "    return verifier;",
                  "}",
                  "",
                  "// Convert Base64 → Base64URL",
                  "function base64UrlEncode(wordArray) {",
                  "    return CryptoJS.enc.Base64.stringify(wordArray)",
                  "        .replace(/\\+/g, \"-\")",
                  "        .replace(/\\//g, \"_\")",
                  "        .replace(/=+$/, \"\");",
                  "}",
                  "",
                  "// 1 Generate verifier",
                  "const code_verifier = generateCodeVerifier();",
                  "",
                  "// 2 SHA256 hash",
                  "const hashed = CryptoJS.SHA256(code_verifier);",
                  "",
                  "// 3 Base64URL encode",
                  "const code_challenge = base64UrlEncode(hashed);",
                  "",
                  "// 4 Save variables",
                  "pm.collectionVariables.set(\"code_verifier\", code_verifier);",
                  "pm.collectionVariables.set(\"code_challenge\", code_challenge);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{auth_base_url}}/authorize?response_type=code&client_id={{client_id}}&redirect_uri={{redirect_uri}}&state=scope_string_123&scope=playlist-read-private&code_challenge={{code_challenge}}&code_challenge_method=S256&code_verifier={{code_verifier}}",
              "host": ["{{auth_base_url}}"],
              "path": ["authorize"],
              "query": [
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirect_uri}}"
                },
                {
                  "key": "state",
                  "value": "scope_string_123"
                },
                {
                  "key": "scope",
                  "value": "playlist-read-private"
                },
                {
                  "key": "code_challenge",
                  "value": "{{code_challenge}}"
                },
                {
                  "key": "code_challenge_method",
                  "value": "S256"
                },
                {
                  "key": "code_verifier",
                  "value": "{{code_verifier}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "02 - Exchange Authorization Code for Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json()",
                  "",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Access token is not empty\", function () {",
                  "    pm.expect(response.access_token).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test(\"refresh token is not empty\", function () {",
                  "    pm.expect(response.refresh_token).to.not.be.empty;",
                  "});",
                  "",
                  "",
                  "if (response.access_token !== null && response.access_token !== null) {",
                  "    pm.environment.set(\"access_token\", response.access_token)",
                  "    pm.environment.set(\"refresh_token\", response.refresh_token)",
                  "}",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "text",
                  "uuid": "aaf80e7d-0cac-4613-bbb9-92983dccc1e2"
                },
                {
                  "key": "code",
                  "value": "{{authorization_code_pkce}}",
                  "type": "text",
                  "uuid": "9d5d1a25-2b21-4548-9447-ef4b3e179616"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirect_uri}}",
                  "type": "text",
                  "uuid": "2f87f67f-eda4-4020-81cc-2504b846a63b"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text",
                  "uuid": "233ee0c1-7583-422f-91a9-d1c86b5a40c1"
                },
                {
                  "key": "code_verifier",
                  "value": "{{code_verifier}}",
                  "type": "text",
                  "uuid": "19411060-fc98-4a75-9f83-100bedbc6326"
                }
              ]
            },
            "url": {
              "raw": "{{auth_base_url}}/api/token",
              "host": ["{{auth_base_url}}"],
              "path": ["api", "token"]
            }
          },
          "response": []
        },
        {
          "name": "03 - Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseBody = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Access token is not empty\", () => {",
                  "    pm.expect(responseBody.access_token).to.not.be.empty;",
                  "    pm.expect(responseBody.access_token).to.be.a('string');",
                  "});",
                  "",
                  "if (responseBody.access_token !== null) {",
                  "    pm.environment.set(\"access_token\", responseBody.access_token);",
                  "}",
                  "",
                  "//Because this uses token rotation strategy",
                  "if (responseBody.refresh_token !== null) {",
                  "    pm.environment.set(\"refresh_token\", responseBody.refresh_token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "password",
                  "value": "{{client_secret}}",
                  "type": "string"
                },
