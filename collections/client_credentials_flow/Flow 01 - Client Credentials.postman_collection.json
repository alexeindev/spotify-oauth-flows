{
  "info": {
    "name": "Flow 01 - Client Credentials",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52148220"
  },
  "item": [
    {
      "name": "Positive Scenarios",
      "item": [
        {
          "name": "POST /token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const schema = {",
                  "    type: \"object\",",
                  "    required: [\"access_token\", \"token_type\", \"expires_in\"],",
                  "    properties: {",
                  "        access_token: { type: \"string\", minLength: 1 },",
                  "        token_type:   { type: \"string\", enum: [\"Bearer\", \"bearer\"] },",
                  "        expires_in:   { type: \"number\", minimum: 1 }",
                  "    },",
                  "    additionalProperties: false",
                  "};",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Status 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response schema is correct\", () => {",
                  "    pm.response.to.have.jsonSchema(schema)",
                  "});",
                  "",
                  "pm.test(\"Token type is Bearer\", () => {",
                  "    pm.expect(response.token_type).to.eql(\"Bearer\")",
                  "});",
                  "",
                  "pm.test(\"Token variable is stored correctly\", () => {",
                  "    if (response.access_token){",
                  "        pm.expect(response.access_token).to.not.be.null",
                  "        pm.collectionVariables.set(\"access_token\", response.access_token)",
                  "        pm.expect(pm.collectionVariables.get(\"access_token\")).to.eql(response.access_token)",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "password",
                  "value": "{{client_secret}}",
                  "type": "string"
                },
                {
                  "key": "username",
                  "value": "{{client_id}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text",
                  "uuid": "aeb53763-04b0-451b-b760-5d43b40c958b"
                }
              ]
            },
            "url": {
              "raw": "https://accounts.spotify.com/api/token",
              "protocol": "https",
              "host": ["accounts", "spotify", "com"],
              "path": ["api", "token"]
            }
          },
          "response": []
        },
        {
          "name": "GET /artist",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.spotify.com/v1/artists/:artist_id",
              "protocol": "https",
              "host": ["api", "spotify", "com"],
              "path": ["v1", "artists", ":artist_id"],
              "variable": [
                {
                  "key": "artist_id",
                  "value": "7Ln80lUS6He07XvHI8qqHH"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Negative scenarios",
      "item": [
        {
          "name": "POST /token - Invalid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Status 400\", () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Error is invalid_client\", () => {",
                  "    pm.expect(response.error).to.eql(\"invalid_client\");",
                  "});",
                  "",
                  "pm.test(\"Error description is correct\", () => {",
                  "    pm.expect(response.error_description).to.eql(\"Invalid client\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"invalid_client_id\", \"bad_\" + Date.now());",
                  "pm.variables.set(\"invalid_client_secret\", \"bad_\" + Math.random().toString(36).slice(2));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "password",
                  "value": "{{invalid_client_secret}}",
                  "type": "string"
                },
                {
                  "key": "username",
                  "value": "{{invalid_client_id}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text",
                  "uuid": "aeb53763-04b0-451b-b760-5d43b40c958b"
                }
              ]
            },
            "url": {
              "raw": "https://accounts.spotify.com/api/token",
              "protocol": "https",
              "host": ["accounts", "spotify", "com"],
              "path": ["api", "token"]
            }
          },
          "response": []
        },
        {
          "name": "GET /artist - Invalid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 401\", () => {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"Error message is 'Invalid access token'\", () => {",
                  "    pm.expect(pm.response.json().error.message).to.eql(\"Invalid access token\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const valid_access_token = pm.collectionVariables.get(\"access_token\");",
                  "pm.variables.set(\"invalid_access_token\", valid_access_token.slice(0, -5) + \"xxxxx\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{invalid_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.spotify.com/v1/artists/:artist_id",
              "protocol": "https",
              "host": ["api", "spotify", "com"],
              "path": ["v1", "artists", ":artist_id"],
              "variable": [
                {
                  "key": "artist_id",
                  "value": "7Ln80lUS6He07XvHI8qqHH"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /artist - Invalid Artist ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404\", () => {",
                  "    pm.response.to.have.status(404);    ",
                  "})",
                  "",
                  "pm.test(\"Response body contains error message\", () => {",
                  "    pm.expect(pm.response.json().error.message).to.eql(\"Resource not found\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.spotify.com/v1/artists/:artist_id",
              "protocol": "https",
              "host": ["api", "spotify", "com"],
              "path": ["v1", "artists", ":artist_id"],
              "variable": [
                {
                  "key": "artist_id",
                  "value": "7Ln80lUS6He07XvHI8qqxx"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
